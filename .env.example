# =====================================================================
# Vorlage fuer die Umgebungsvariablen – kopieren nach .env und anpassen.
#   cp .env.example .env
#
# Verwendet von:
#   - docker run db ...  (MYSQL_* Variablen)
#   - Backend application.properties (spring.datasource.*)
#
# Laden vor dem docker-Befehl:  set -a; source .env; set +a
# =====================================================================
DB_ROOT_PASSWORD=change-me-root
DB_USER=steam_user
DB_PASSWORD=change-me
DB_NAME=steam_library
DB_HOST=localhost
DB_PORT=3306
